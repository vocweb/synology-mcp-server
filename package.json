{
  "name": "synology-office-mcp",
  "version": "0.4.5",
  "description": "MCP server exposing Synology Drive, Spreadsheet, MailPlus, and Calendar as AI-agent tools",
  "type": "module",
  "license": "MIT",
  "author": "Tien <chutien@gmail.com>",
  "repository": {
    "type": "git",
    "url": "https://github.com/vocweb/synology-mcp-server.git"
  },
  "homepage": "https://github.com/vocweb/synology-mcp-server#readme",
  "bugs": {
    "url": "https://github.com/vocweb/synology-mcp-server/issues"
  },
  "keywords": [
    "mcp",
    "synology",
    "drive",
    "calendar",
    "mailplus",
    "ai-agent",
    "model-context-protocol"
  ],
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=9.0.0"
  },
  "main": "./dist/index.js",
  "exports": {
    ".": "./dist/index.js"
  },
  "bin": {
    "synology-mcp": "./dist/index.js"
  },
  "files": [
    "dist",
    ".env.example",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "node --watch dist/index.js",
    "start": "node dist/index.js",
    "start:sse": "MCP_TRANSPORT=sse node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src --max-warnings 0",
    "lint:fix": "eslint src --fix",
    "format": "prettier --write \"src/**/*.ts\" \"tests/**/*.ts\"",
    "typecheck": "tsc --noEmit",
    "prepare": "husky"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.11.0",
    "dotenv": "^16.4.7",
    "form-data": "^4.0.1",
    "undici": "^8.1.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.25.0",
    "@types/node": "^22.0.0",
    "@vitest/coverage-v8": "^3.1.2",
    "eslint": "^9.25.0",
    "eslint-config-prettier": "^10.1.2",
    "husky": "^9.1.7",
    "lint-staged": "^15.5.1",
    "msw": "^2.7.3",
    "prettier": "^3.5.3",
    "tsup": "^8.4.0",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.30.1",
    "vitest": "^3.1.2"
  }
}
